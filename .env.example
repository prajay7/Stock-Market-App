ALPHA_VANTAGE_API_KEY=
POLYGON_API_KEY=
API_PORT=8000
# Historical/live market data provider default
DATA_PROVIDER=yahoo
# News provider default
NEWS_PROVIDER=google
OPENAI_PREDICT_ENABLED=false
OPENAI_PREDICT_MODEL_NAME=google/gemini-2.5-flash
# OpenRouter profile aliases used by openai_stock_llm_* model selectors
FAST_MODEL=google/gemini-2.5-flash
SEARCH_MODEL=perplexity/sonar
CHEAP_MODEL=deepseek/deepseek-chat
# For OpenRouter, use: https://openrouter.ai/api/v1
OPENAI_PREDICT_BASE_URL=https://api.openai.com/v1
OPENAI_PREDICT_TEMPERATURE=0.0
OPENAI_PREDICT_TIMEOUT_SEC=20.0
OPENAI_PREDICT_API_KEY=
AUTOMATION_ENABLED=false
AUTOMATION_INTERVAL_MINUTES=30
AUTOMATION_MAX_SYMBOLS=120
AUTOMATION_GLOBAL_SYMBOLS_RAW=
AUTOMATION_PREDICTION_MODEL=auto
AUTOMATION_HORIZON_DAYS=1
AUTOMATION_INCLUDE_LIVE_QUOTE=false
AUTOMATION_TOP_SUGGESTIONS=25
AUTOMATION_FORCE_NEWS_REFRESH=true
AUTOMATION_STEP_TIMEOUT_SEC=45
DATABASE_URL=sqlite:///./stock_ai.db
DEFAULT_SYMBOLS=RELIANCE, TCS, INFY, HDFCBANK, ICICIBANK, SBIN
BENCHMARK_SYMBOL=SPY
MODEL_DIR=./data/models
RAW_DATA_DIR=./data/raw
PROCESSED_DATA_DIR=./data/processed
OUTPUT_DIR=./data/outputs
HISTORICAL_INTERVAL=1d
HISTORICAL_LOOKBACK_DAYS=3650
NEWS_REFRESH_MINUTES=30
SCHEDULER_ENABLED=true
TRANSACTION_COST_BPS=10
TOP_N_SELECTION=5
LOG_LEVEL=INFO
NEWS_TICKER_ALIASES_PATH=./data/ticker_aliases.json
NEWS_COMPANY_TICKER_MAP_PATH=./data/company_tickers.json
NEWS_PRICE_REACTION_MAX_ABS_PCT=3.5
NEWS_PRICE_MOVE_EARLY_THRESHOLD_PCT=1.5
NEWS_PRICE_MOVE_LATE_THRESHOLD_PCT=4.0
NEWS_MIN_SIGNAL_SCORE=0.60
NEWS_TOP_OPPORTUNITIES_LIMIT=10
NEWS_PERSIST_SIGNALS_ENABLED=true
BACKTEST_ENABLED=true
BACKTEST_HORIZONS_RAW=1,3,5,7
BACKTEST_SCHEDULER_ENABLED=false
BACKTEST_SCHEDULER_INTERVAL_MINUTES=60
BENCHMARK_TICKER=
TRADING_DAY_FALLBACK_MODE=next_available_close
MAX_BACKTEST_ROWS_IN_UI=500

# Watchlist and alert settings
ALERTS_ENABLED=true
ALERT_SCAN_ENABLED=false
ALERT_SCAN_INTERVAL_MINUTES=60
DEFAULT_COOLDOWN_MINUTES=60
ENABLED_NOTIFICATION_CHANNELS_RAW=in_app
MAX_ALERTS_IN_UI=500
MAX_RECENT_SIGNALS_FOR_ALERT_SCAN=100

# Notification channel configs (optional)
WEBHOOK_URL=
WEBHOOK_TIMEOUT_SEC=10.0
SMTP_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
ALERT_EMAIL_FROM=
ALERT_EMAIL_TO=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
SLACK_WEBHOOK_URL=
